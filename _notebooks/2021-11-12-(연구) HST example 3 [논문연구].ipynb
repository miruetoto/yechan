    "## 1. remove trash\n",
    "!rm -rf ~/.local/share/Trash/files/*\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib\n",
    "matplotlib.rc('image', cmap='Greys')\n",
    "import rpy2 \n",
    "%load_ext rpy2.ipython\n",
    "%run pybase\n",
    "%run heavysnow \n",
    "plt.style.use('ggplot')"
   ]
