   "source": [
    "#### $\\alpha$가 너무 크면 (alpha=0.83) $\\to$ 다른의미에서 비효율적 + 위험함"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 129,
   "metadata": {},
   "outputs": [],
   "source": [
    "alpha = 0.83\n",
    "\n",
    "losses=[] #기록\n",
    "yhats=[] #기록\n",
    "Whats=[] #기록\n",
    "\n",
    "What = torch.tensor([-5.,10.],requires_grad=True)\n",
    "\n",
    "for epoc in range(30):\n",
    "    Whats=Whats+[What.data.tolist()] ## 기록 \n",
    "    What.grad = None\n",
    "    yhat=X@What\n",
    "    yhats=yhats+[yhat.data.tolist()] ## 기록 \n",
    "    loss=torch.mean((y-yhat)**2)\n",
    "    losses.append(loss.item()) ## 기록 \n",
    "    loss.backward()\n",
    "    What.data=What.data - alpha * What.grad.data    "
   ]
  },
