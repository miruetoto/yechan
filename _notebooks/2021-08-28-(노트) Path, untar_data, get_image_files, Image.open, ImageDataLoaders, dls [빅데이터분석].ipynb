   "cell_type": "code",
   "execution_count": 40,
   "id": "2e8d7a17-4187-4a3d-bf04-6b86025fe78e",
   "metadata": {},
   "outputs": [],
   "source": [
    "def label_func(fname):\n",
    "    return \"cat\" if fname[0].isupper() else \"dog\" # 파일명의 첫번짜 글자가 대문자이면 cat"
   ]
  },
  {
