   "source": [
    "ssarslt<-ssa(cosmeanf, kind=\"2d-ssa\",L=c(4,4))\n",
    "plot(ssarslt,type=\"vectors\")\n",
    "decomprslt<-reconstruct(ssarslt,groups=list(LF=c(1,2,3),HF=c(4)))\n",
    "plot(decomprslt)"
   ]
  },
