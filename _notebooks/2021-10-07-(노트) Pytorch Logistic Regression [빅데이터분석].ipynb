  {
   "cell_type": "markdown",
   "id": "8e185a1b-d038-4992-bba2-d97140206d13",
   "metadata": {},
   "source": [
    "### MSEloss 와 binary cross entropy 비교"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "98f282ed-aaed-4bba-a834-e0ef3ede60b4",
   "metadata": {},
   "source": [
    "#### 손실함수의 모양비교 "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "6b1778db-66ee-470c-b990-0e3cde553859",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 129,
   "id": "9be8f476-57cc-41e3-a8b5-4051a74dff26",
   "metadata": {},
   "outputs": [],
   "source": [
    "torch.manual_seed(1)\n",
    "X=torch.linspace(-1,1,2000).reshape(2000,1)\n",
    "w0= -1\n",
    "w1= 5\n",
    "u=X*w1+w0\n",
    "v=torch.exp(u)/(1+(torch.exp(u)))\n",
    "y=torch.bernoulli(v)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 130,
   "id": "82f0b118-f9dd-4d92-91fb-bad1c2bc2576",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 131,
   "id": "17c11438-a625-4a11-b14e-8b59e60e4a39",
   "metadata": {},
   "outputs": [],
   "source": [
    "_w0 = np.arange(-10, 3, 0.05)\n",
    "_w1 = np.arange(-1, 10, 0.05)\n",
    "_w0,_w1 = np.meshgrid(_w0,_w1,indexing='ij')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 132,
   "id": "69648d2f-4802-476a-960b-9abe353d161b",
   "metadata": {},
   "outputs": [],
   "source": [
    "_w0=_w0.reshape(-1)\n",
    "_w1=_w1.reshape(-1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 133,
   "id": "1ce1e478-d296-433a-ae74-907024f27e10",
   "metadata": {},
   "outputs": [],
   "source": [
    "def lossfn_crossenp(w0,w1): \n",
    "    yhat= torch.exp(w0+w1*X)/(1+torch.exp(w0+w1*X))\n",
    "    loss=- torch.mean((y*torch.log(yhat) + (1-y)*torch.log(1-yhat)))\n",
    "    return loss.tolist()\n",
    "def lossfn_mse(w0,w1):\n",
    "    yhat= torch.exp(w0+w1*X)/(1+torch.exp(w0+w1*X))\n",
    "    loss=torch.mean((y-yhat)**2)\n",
    "    return loss.tolist()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 134,
   "id": "24583ca5-20f0-4e9d-8dd5-aa8afe59e52c",
   "metadata": {
    "tags": []
   },
   "outputs": [],
   "source": [
    "_l1=list(map(lossfn_crossenp,_w0,_w1))\n",
    "_l2=list(map(lossfn_mse,_w0,_w1))"
   ]
  },
