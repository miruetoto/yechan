   "id": "7d1140a9-65ea-4df1-90db-2a72d6eab1c7",
   "metadata": {},
   "source": [
    "`-` 아키텍쳐, 손실함수, 옵티마이저"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "75191bcd-f003-4e94-a4ad-61ea448c9ea9",
   "metadata": {},
   "outputs": [],
   "source": [
    "torch.manual_seed(43052)\n",
    "l1=torch.nn.Linear(in_features=1,out_features=1,bias=True)\n",
    "a1=torch.nn.Sigmoid() \n",
    "net=torch.nn.Sequential(l1,a1)\n",
    "#loss=torch.mean((y-yhat)**2)????? <-- 이거 아닙니다!! \n",
    "optimizer=torch.optim.SGD(net.parameters(),lr=0.05)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "7940c072-34dc-458e-a7fc-43d451e03ba1",
   "metadata": {},
   "outputs": [
