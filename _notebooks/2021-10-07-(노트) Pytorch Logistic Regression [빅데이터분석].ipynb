   ],
   "source": [
    "plt.scatter(X,y,alpha=0.01)\n",
    "plt.plot(X,net(X).data,'--')\n",
    "plt.plot(X,v,'--')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2fbb283d-94d8-49c9-b89c-7ad1dbc8d1db",
   "metadata": {},
   "source": [
    "`-` step1~4"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "f706727e-cb7c-46b3-8f74-ef23c4fda169",
   "metadata": {},
   "outputs": [],
   "source": [
    "for epoc in range(10000):\n",
    "    ## 1 \n",
    "    yhat=net(X) \n",
    "    ## 2 \n",
    "    loss=-torch.mean(y*torch.log(yhat)+(1-y)*torch.log(1-yhat))\n",
    "    ## 3 \n",
    "    loss.backward()\n",
    "    ## 4 \n",
    "    optimizer.step()\n",
    "    net.zero_grad()"
   ]
  },
