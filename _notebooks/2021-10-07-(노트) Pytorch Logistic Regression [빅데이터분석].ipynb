   "source": [
    "`-` step1~4"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "d204c1ca-38bf-40ff-b2c9-bd34d13a6d49",
   "metadata": {},
   "outputs": [],
   "source": [
    "for epoc in range(10000):\n",
    "    ## 1 \n",
    "    yhat=net(X) \n",
    "    ## 2 \n",
    "    loss=torch.mean((y-yhat)**2)\n",
    "    ## 3 \n",
    "    loss.backward()\n",
    "    ## 4 \n",
    "    optimizer.step()\n",
    "    net.zero_grad()"
   ]
