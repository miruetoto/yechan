   "source": [
    "#### 아키텍처, 옵티마이저 "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 143,
   "id": "a5281b2b-03fc-4afd-997b-9dd484cd9027",
   "metadata": {},
   "outputs": [],
   "source": [
    "l1=torch.nn.Linear(in_features=1,out_features=1,bias=True)\n",
    "a1=torch.nn.Sigmoid() \n",
    "net=torch.nn.Sequential(l1,a1)\n",
    "optimizer=torch.optim.SGD(net.parameters(),lr=0.05)"
   ]
  },
  {
   "cell_type": "markdown",
