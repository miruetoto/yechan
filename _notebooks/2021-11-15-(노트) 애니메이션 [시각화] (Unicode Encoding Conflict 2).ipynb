   "source": [
    "fig, ax =  plt.subplots()\n",
    "plt.plot(x,y)\n",
    "ims = [ax.plot(x[:i],y[:i],'.r') for i in range(30)]\n",
    "ani = animation.ArtistAnimation(fig, ims)\n",
    "plt.close()\n",
    "ani"
   ]
