   "source": [
    "def read_nii(filepath):\n",
    "    '''\n",
    "    Reads .nii file and returns pixel array\n",
    "    '''\n",
    "    ct_scan = nib.load(filepath)\n",
    "    array   = ct_scan.get_fdata()\n",
    "    array   = np.rot90(np.array(array))\n",
    "    return(array)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "265a8e3c-0ab1-47a3-9b32-33f9ceae925d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Read sample\n",
    "sample_ct   = read_nii(modifiedlist.loc[0,'ct_scan'])\n",
    "sample_lung = read_nii(modifiedlist.loc[0,'lung_mask'])\n",
    "sample_infe = read_nii(modifiedlist.loc[0,'infection_mask'])\n",
    "sample_all  = read_nii(modifiedlist.loc[0,'lung_and_infection_mask'])"
   ]
  },
