    "import numpy as np\n",
    "data = (\n",
    "    np.random.normal(size=(100, 3)) *\n",
    "    np.array([[1, 1, 1]]) +\n",
    "    np.array([[28, 77, 1]])\n",
    ").tolist()\n",
    "m = folium.Map([28,77],tiles='OpenStreetMap', zoom_start=6,scrollWheelZoom=False)\n",
    "folium.plugins.HeatMap(data).add_to(m)\n",
    "m"
   ]
