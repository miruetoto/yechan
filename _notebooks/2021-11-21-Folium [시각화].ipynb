   "metadata": {},
   "outputs": [],
   "source": [
    "np.random.seed(3141592)\n",
    "initial_data = (\n",
    "    np.random.normal(size=(100, 2)) * 0.0001 +\n",
    "    np.array([[35.836603154469884, 127.11406532500682]])\n",
    ")\n",
    "#Generate Heatmap movement dataset\n",
    "move_data = np.random.normal(size=(100, 2)) * 0.0001 \n",
    "data = [(initial_data + move_data * i).tolist() for i in range(100)]\n",
    "weight = 1  # default value\n",
    "for time_entry in data:\n",
    "    for row in time_entry:\n",
    "        row.append(weight)\n",
    "        row.append(np.random.randn())"
   ]
